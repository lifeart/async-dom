{
  "manifest_version": 3,
  "name": "async-dom DevTools",
  "version": "1.0.0",
  "description": "Chrome DevTools extension for inspecting async-dom virtual DOM, scheduler, and mutation flow.",
  "devtools_page": "devtools.html",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
